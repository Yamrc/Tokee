{
	"extends": "astro/tsconfigs/strict",
	"compilerOptions": {
		"types": [
			"astro/client",
			"vite/client"
		],
		"paths": {
			"@/*": [
				"./src/*"
			],
			"@config": [
				"./src/config.ts"
			],
			"@layouts/*": [
				"./src/layouts/*"
			],
			"@islands/*": [
				"./src/islands/*"
			],
			"@lib/*": [
				"./src/lib/*"
			],
			"@scripts/*": [
				"./src/scripts/*"
			],
			"@styles/*": [
				"./src/styles/*"
			]
		}
	},
	"include": [
		".astro/types.d.ts",
		"src/**/*",
		"astro.config.mjs"
	],
	"exclude": [
		"dist",
		"node_modules"
	]
}
